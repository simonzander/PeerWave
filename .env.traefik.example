# PeerWave Traefik Deployment Configuration
# Copy this file to .env before deploying with docker-compose.traefik.yml

# ============================================
# Domain Configuration
# ============================================
DOMAIN=app.yourdomain.com
LIVEKIT_TURN_DOMAIN=app.yourdomain.com

# ============================================
# Security Credentials (CHANGE THESE!)
# ============================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_32_CHARS

# LiveKit API Credentials
LIVEKIT_API_KEY=CHANGE_THIS
LIVEKIT_API_SECRET=CHANGE_THIS

# ============================================
# Email Configuration (Optional)
# ============================================
# For meeting invitations and notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ============================================
# SMTP Configuration (Alternative naming)
# ============================================
SMTP_HOST=${EMAIL_HOST}
SMTP_PORT=${EMAIL_PORT}
SMTP_SECURE=${EMAIL_SECURE}
SMTP_USER=${EMAIL_USER}
SMTP_PASSWORD=${EMAIL_PASS}
SMTP_FROM=${EMAIL_USER}
